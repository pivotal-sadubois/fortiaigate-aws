# ------------------------------------------------------------------------------------------
# Function Name ......: verifySpotPlacementScrores
# Function Purpose ...: Verify Spot Placement Scores
# ------------------------------------------------------------------------------------------
# Argument ($1) ......: AWS_REGION
# Dependancies: ......: 
#                     :
# ------------------------------------------------------------------------------------------
# Return Value .......: Placement Score (1, 2 or 3)
# ------------------------------------------------------------------------------------------
verifySpotPlacementScrores() {
  REGION="$1"

  aws ec2 get-spot-placement-scores \
      --target-capacity 1 \
      --single-availability-zone \
      --instance-types g5.2xlarge g5.4xlarge --no-cli-pager > /tmp/tempfile.json

  if [ "$REGION" == "" ]; then 
    cat /tmp/tempfile.json
  else
    avz=$(jq -r --arg key "$REGION" '[.SpotPlacementScores[] | select(.Region == $key) | .AvailabilityZoneId] | join(" ")' /tmp/tempfile.json)

    score=0
    for n in $avz; do
      scr=$(jq -r --arg reg "$REGION" --arg avz "$n" '.SpotPlacementScores[] | select(.Region == $reg and .AvailabilityZoneId == $avz).Score' /tmp/tempfile.json)
      let score=score+scr
    done

    echo "$score"
  fi
}

# ------------------------------------------------------------------------------------------
# Function Name ......: installEKSCluster
# Function Purpose ...: Install the EKS Cluster without NodeGroups
# ------------------------------------------------------------------------------------------
# Argument ($1) ......:
# Dependancies: ......: AWS_REGION, EKS_CLUSTER_NAME
# ------------------------------------------------------------------------------------------
# Return Value .......:
# ------------------------------------------------------------------------------------------
installEKSCluster() {
  messageTitle "AWS EKS Kubernetes Cluster Deployment"

  cluster=$(aws eks list-clusters --region $AWS_REGION | jq --arg key "$EKS_CLUSTER_NAME" -r '.clusters[] | select(. == $key)')
  if [ "$cluster" != "$EKS_CLUSTER_NAME" ]; then
    eksctl create cluster --name "$EKS_CLUSTER_NAME" --region $AWS_REGION --without-nodegroup > /tmp/error.log 2>&1; ret=$?
    if [ $ret -ne 0 ]; then
      logMessages /tmp/error.log
      echo "ERROR: Cluster creatation failed"
      exit
    fi

    echo " ▪ Update Kubeconfig for the EKS Cluster"
    aws eks update-kubeconfig --name $EKS_CLUSTER_NAME --region $AWS_REGION > /dev/null 2>&1

    echo " ▪  Write EKS configuration to state file (\$HOME/.fortiaigate.stat)"
    echo "export EKS_CLUSTER_NAME=$EKS_CLUSTER_NAME"       >  $HOME/.fortiaigate.stat
    echo "export AWS_REGION=$AWS_REGION"                   >> $HOME/.fortiaigate.stat
  else
    stt=$(aws eks describe-cluster --name $EKS_CLUSTER_NAME --region $AWS_REGION --query "cluster.status" --output text --no-cli-pager)
    if [ "$stt" == "ACTIVE" ]; then
      echo " ▪ EKS Cluster '$EKS_CLUSTER_NAME' already installed with status ($stt)"
    else
      echo "ERROR: Cluster is currently in ($stt) state. Please fix or remove the cluster to proceede"
      exit
    fi
  fi

}

# ------------------------------------------------------------------------------------------
# Function Name ......: installNodeGroup
# Function Purpose ...: Install the EKS NoadeGroup gpu-ondemand-ng or gpu-spot-ng
# ------------------------------------------------------------------------------------------
# Argument ($1) ......:
# Dependancies: ......: AWS_REGION, EKS_CLUSTER_NAME
# ------------------------------------------------------------------------------------------
# Return Value .......: 0 - Success, 1 - failed
# ------------------------------------------------------------------------------------------
installNodeGroup() {
  # 8–10 Very likely to succeed
  # 5–7 Might work
  # 1–4 High chance of failure
  spotscore=$(verifySpotPlacementScrores $AWS_REGION)

  if [ $spotscore -lt 3 ]; then
    export EKS_NODEGROUP_TYPE=gpu-ondemand-ng
    echo " ▪ To few gpu-spot-ng availability zones in Region: $AWS_REGION, deployeing gpu-ondemand-ng instead"
  else
    export EKS_NODEGROUP_TYPE=gpu-spot-ng
    echo " ▪ Trying to go with gpu-ondemand-ng NodeGroups"
  fi

  echo " ▪  Write EKS configuration to state file (\$HOME/.fortiaigate.stat)"
  echo "export EKS_NODEGROUP_TYPE=$EKS_NODEGROUP_TYPE"   >> $HOME/.fortiaigate.stat

  nodegroups=$(aws eks list-nodegroups  --cluster-name $EKS_CLUSTER_NAME --region $AWS_REGION  --no-cli-pager | jq -r '.nodegroups[]')
  if [ "$nodegroups" == "" ]; then
    echo " ▪ Creating EKS NodeGroup type $EKS_NODEGROUP_TYPE"
    sed -e "s/CLUSTER/$EKS_CLUSTER_NAME/g" -e "s/REGION/$AWS_REGION/g"  files/${EKS_NODEGROUP_TYPE}-template.yaml > /tmp/${EKS_NODEGROUP_TYPE}.yaml
    eksctl create nodegroup --config-file /tmp/${EKS_NODEGROUP_TYPE}.yaml > /tmp/error.log 2>&1; ret=$?
    if [ $ret -ne 0 ]; then
      logMessages /tmp/error.log
      echo "ERROR: NodeGroup creatation failed"
      exit 1
    fi
  else
    echo " ▪ EKS NodeGroup for cluster '$EKS_CLUSTER_NAME' already installed"
  fi

  messageTitle " ▪ Update Kubeconfig for the EKS Cluster"
  aws eks update-kubeconfig --name $EKS_CLUSTER_NAME --region $AWS_REGION > /dev/null 2>&1
}

# ------------------------------------------------------------------------------------------
# Function Name ......: installALBloadBalancer
# Function Purpose ...: Install the ALB Load Balancer
# ------------------------------------------------------------------------------------------
# Argument ($1) ......:
# Dependancies: ......: AWS_REGION, EKS_CLUSTER_NAME
# ------------------------------------------------------------------------------------------
# Return Value .......: 0 - Success, 1 - failed
# ------------------------------------------------------------------------------------------
installALBloadBalancer() {

  SA_NAMESPACE="kube-system"
  POLICY_NAME="AWSLoadBalancerControllerIAMPolicy"
  ROLE_NAME="AmazonEKSLoadBalancerControllerRole"

  messageTitle "ALB Load Balancer for EKS Kubernetes Cluster"

  # Get AWS Account ID from current login/session
  AWS_ACCOUNT_ID=$(aws sts get-caller-identity --query Account --output text 2>/tmp/error.log); ret=$?
  if [ $ret -ne 0 -o -z "$AWS_ACCOUNT_ID" ]; then
    logMessages /tmp/error.log
    echo "ERROR: Failed to get AWS Account ID from current login"
    echo "       => aws sts get-caller-identity --query Account --output text"
    exit 1
  fi

  kubectl -n "$SA_NAMESPACE" get deployment aws-load-balancer-controller >/dev/null 2>&1; ret=$?
  if [ $ret -ne 0 ]; then
    echo " ▪ install the ALB Load Balancer"
    echo " ▪ AWS Account ID .......: $AWS_ACCOUNT_ID"

    # Ensure the IAM OIDC provider exists
    eksctl utils associate-iam-oidc-provider \
      --cluster "$EKS_CLUSTER_NAME" \
      --region "$AWS_REGION" \
      --approve > /tmp/error.log 2>&1; ret=$?

    if [ $ret -ne 0 ]; then
      logMessages /tmp/error.log
      echo "ERROR: ALB Load Balancer creation failed"
      echo "       => eksctl utils associate-iam-oidc-provider --cluster $EKS_CLUSTER_NAME --region $AWS_REGION --approve"
      exit 1
    fi

    # Ensure the IAM policy exists
    aws iam get-policy \
      --policy-arn "arn:aws:iam::$AWS_ACCOUNT_ID:policy/$POLICY_NAME" >/dev/null 2>&1; ret=$?

    if [ $ret -ne 0 ]; then
      echo " ▪ create IAM policy $POLICY_NAME"

      curl -fsSL -o /tmp/iam_policy.json \
        https://raw.githubusercontent.com/kubernetes-sigs/aws-load-balancer-controller/main/docs/install/iam_policy.json \
        > /tmp/error.log 2>&1; ret=$?

      if [ $ret -ne 0 ]; then
        logMessages /tmp/error.log
        echo "ERROR: Downloading IAM policy failed"
        echo "       => curl -fsSL -o /tmp/iam_policy.json https://raw.githubusercontent.com/kubernetes-sigs/aws-load-balancer-controller/main/docs/install/iam_policy.json"
        exit 1
      fi

      aws iam create-policy \
        --policy-name "$POLICY_NAME" \
        --policy-document file:///tmp/iam_policy.json > /tmp/error.log 2>&1; ret=$?

      if [ $ret -ne 0 ]; then
        logMessages /tmp/error.log
        echo "ERROR: Install IAM Policy failed"
        echo "       => aws iam create-policy --policy-name $POLICY_NAME --policy-document file:///tmp/iam_policy.json"
        exit 1
      fi
    else
      echo " ▪ IAM policy already exists"
    fi

    # Create or update the IAM service account
    echo " ▪ create IAM service account aws-load-balancer-controller"
    eksctl create iamserviceaccount \
      --cluster "$EKS_CLUSTER_NAME" \
      --region "$AWS_REGION" \
      --namespace "$SA_NAMESPACE" \
      --name aws-load-balancer-controller \
      --role-name "$ROLE_NAME" \
      --attach-policy-arn "arn:aws:iam::$AWS_ACCOUNT_ID:policy/$POLICY_NAME" \
      --override-existing-serviceaccounts \
      --approve > /tmp/error.log 2>&1; ret=$?

    if [ $ret -ne 0 ]; then
      logMessages /tmp/error.log
      echo "ERROR: Creating Service Account failed"
      echo "       => eksctl create iamserviceaccount \\"
      echo "            --cluster $EKS_CLUSTER_NAME \\"
      echo "            --region $AWS_REGION \\"
      echo "            --namespace $SA_NAMESPACE \\"
      echo "            --name aws-load-balancer-controller \\"
      echo "            --role-name $ROLE_NAME \\"
      echo "            --attach-policy-arn arn:aws:iam::$AWS_ACCOUNT_ID:policy/$POLICY_NAME \\"
      echo "            --override-existing-serviceaccounts \\"
      echo "            --approve"
      exit 1
    fi

    echo " ▪ Add Helm Repo https://aws.github.io/eks-charts"
    helm repo add eks https://aws.github.io/eks-charts >/dev/null 2>&1 || true

    helm repo update > /tmp/error.log 2>&1; ret=$?
    if [ $ret -ne 0 ]; then
      logMessages /tmp/error.log
      echo "ERROR: Helm repo update failed"
      echo "       => helm repo update"
      exit 1
    fi

    VPC_ID=$(aws eks describe-cluster \
      --name "$EKS_CLUSTER_NAME" \
      --region "$AWS_REGION" \
      --query 'cluster.resourcesVpcConfig.vpcId' \
      --output text 2>/tmp/error.log); ret=$?

    if [ $ret -ne 0 -o -z "$VPC_ID" ]; then
      logMessages /tmp/error.log
      echo "ERROR: Failed to get VPC ID for cluster $EKS_CLUSTER_NAME"
      echo "       => aws eks describe-cluster --name $EKS_CLUSTER_NAME --region $AWS_REGION --query 'cluster.resourcesVpcConfig.vpcId' --output text"
      exit 1
    fi

    echo " ▪ Installing/upgrading AWS Load Balancer Controller..."
    helm upgrade --install aws-load-balancer-controller eks/aws-load-balancer-controller \
      -n "$SA_NAMESPACE" \
      --set clusterName="$EKS_CLUSTER_NAME" \
      --set serviceAccount.create=false \
      --set serviceAccount.name=aws-load-balancer-controller \
      --set region="$AWS_REGION" \
      --set vpcId="$VPC_ID" > /tmp/error.log 2>&1; ret=$?

    if [ $ret -ne 0 ]; then
      logMessages /tmp/error.log
      echo "ERROR: Helm installation of AWS Load Balancer Controller failed"
      echo "       => helm upgrade --install aws-load-balancer-controller eks/aws-load-balancer-controller -n $SA_NAMESPACE ..."
      exit 1
    fi

    echo " ▪ Waiting for deployment to become ready..."
    kubectl -n "$SA_NAMESPACE" rollout status deployment/aws-load-balancer-controller --timeout=5m > /tmp/error.log 2>&1; ret=$?

    if [ $ret -ne 0 ]; then
      logMessages /tmp/error.log
      echo "ERROR: AWS Load Balancer Controller deployment did not become ready"
      echo "       => kubectl -n $SA_NAMESPACE rollout status deployment/aws-load-balancer-controller --timeout=5m"
      exit 1
    fi
  else
    echo " ▪ ALB Load Balancer already installed"
    #kubectl -n "$SA_NAMESPACE" get deployment aws-load-balancer-controller
  fi
}

# ------------------------------------------------------------------------------------------
# Function Name ......: updateAppDNS
# Function Purpose ...: Update Route53 DNS record for the ALB Ingress hostname
# ------------------------------------------------------------------------------------------
# Argument ($1) ......: <namespace>
# Argument ($2) ......: <fqdn>
# Argument ($3) ......: <hosted-zone-id>
# Dependancies: ......: kubectl, preserveAWScontext, switchToDNSaccount, restoreAWScontext
# ------------------------------------------------------------------------------------------
# Return Value .......: none (exit on error)
# ------------------------------------------------------------------------------------------
updateAppDNS() {
  # Skip this function if ROUT53_DNS_UPDATES is disabled
  [ "$ROUT53_DNS_UPDATES" == "false" ] && return

  APP_NAMESPACE="$1"
  APP_FQDN="$2"
  HOSTED_ZONE_ID="$3"

  APP_INGRESS="${APP_NAMESPACE}-ingress"

  messageTitle "Update Route53 DNS Record for Application"

  if [ -z "$APP_NAMESPACE" -o -z "$APP_FQDN" -o -z "$HOSTED_ZONE_ID" ]; then
    echo "ERROR: Missing arguments"
    echo "       => updateAppDNS <namespace> <fqdn> <hosted-zone-id>"
    exit 1
  fi

  # --------------------------------------------------------------------------
  # Get ALB hostname from ingress
  # --------------------------------------------------------------------------
  ALB_HOSTNAME=$(kubectl -n "$APP_NAMESPACE" get ingress "$APP_INGRESS" \
    -o jsonpath='{.status.loadBalancer.ingress[0].hostname}' 2>/tmp/error.log); ret=$?

  if [ $ret -ne 0 -o -z "$ALB_HOSTNAME" ]; then
    logMessages /tmp/error.log
    echo "ERROR: Failed to get ALB hostname from ingress"
    echo "       => kubectl -n $APP_NAMESPACE get ingress $APP_INGRESS"
    exit 1
  fi

  echo " ▪ APP_FQDN ............: $APP_FQDN"
  echo " ▪ ALB_HOSTNAME ........: $ALB_HOSTNAME"

  # --------------------------------------------------------------------------
  # Switch to DNS account
  # --------------------------------------------------------------------------
  preserveAWScontext
  switchToDNSaccount

  # --------------------------------------------------------------------------
  # Create / Update DNS Record
  # --------------------------------------------------------------------------
  CHANGE_ID=$(aws route53 change-resource-record-sets \
    --hosted-zone-id "$HOSTED_ZONE_ID" \
    --change-batch "{
      \"Changes\": [{
        \"Action\": \"UPSERT\",
        \"ResourceRecordSet\": {
          \"Name\": \"$APP_FQDN\",
          \"Type\": \"CNAME\",
          \"TTL\": 300,
          \"ResourceRecords\": [{
            \"Value\": \"$ALB_HOSTNAME\"
          }]
        }
      }]
    }" \
    --query 'ChangeInfo.Id' \
    --output text 2>/tmp/error.log); ret=$?

  if [ $ret -ne 0 -o -z "$CHANGE_ID" ]; then
    restoreAWScontext
    logMessages /tmp/error.log
    echo "ERROR: Creating Route53 CNAME failed"
    echo "       => aws route53 change-resource-record-sets"
    exit 1
  fi

  echo " ▪ Route53 Change ID ...: $CHANGE_ID"

  # --------------------------------------------------------------------------
  # Wait for Route53 to become INSYNC
  # --------------------------------------------------------------------------
  echo " ▪ Waiting for Route53 change to become INSYNC..."

  while true; do

    STATUS=$(aws route53 get-change \
      --id "$CHANGE_ID" \
      --query 'ChangeInfo.Status' \
      --output text 2>/tmp/error.log); ret=$?

    if [ $ret -ne 0 ]; then
      restoreAWScontext
      logMessages /tmp/error.log
      echo "ERROR: Failed to get Route53 change status"
      exit 1
    fi

    echo " ▪ Route53 Status ......: $STATUS"

    [ "$STATUS" = "INSYNC" ] && break

    sleep 5
  done

  restoreAWScontext

  # --------------------------------------------------------------------------
  # Wait until DNS resolves publicly
  # --------------------------------------------------------------------------
  echo " ▪ Waiting for public DNS propagation..."

  n=0
  while [ $n -lt 30 ]; do

    RESOLVED=$(dig +short "$APP_FQDN" @8.8.8.8 | head -1)

    if [ "$RESOLVED" = "$ALB_HOSTNAME." -o "$RESOLVED" = "$ALB_HOSTNAME" ]; then
      break
    fi

    sleep 5
    let n=n+1
  done

  if [ "$RESOLVED" != "$ALB_HOSTNAME." -a "$RESOLVED" != "$ALB_HOSTNAME" ]; then
    echo "ERROR: DNS propagation timeout"
    echo "       FQDN ............: $APP_FQDN"
    echo "       Expected ........: $ALB_HOSTNAME"
    echo "       Resolved ........: $RESOLVED"
    exit 1
  fi

  echo " ▪ DNS record successfully propagated"
}
