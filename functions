# ------------------------------------------------------------------------------------------
# Function Name ......: prepareEFSinfrastructure
# Function Purpose ...: Create / reuse EFS filesystem, security group and mount targets
# ------------------------------------------------------------------------------------------
# Dependencies .......: AWS_REGION, EKS_CLUSTER_NAME, AWS_PROFILE
# Optional Vars ......: EFS_NAME, EFS_SG_NAME
# Outputs ............: EFS_FILE_SYSTEM_ID, EFS_SECURITY_GROUP_ID
# ------------------------------------------------------------------------------------------
prepareEFSinfrastructure() {

  local EFS_NAME="${EFS_NAME:-efs-$EKS_CLUSTER_NAME}"
  local EFS_SG_NAME="${EFS_SG_NAME:-efs-$EKS_CLUSTER_NAME-sg}"
  local VPC_ID=""
  local SUBNET_IDS=""
  local subnet=""
  local subnetAzId=""
  local MT_ID=""
  local ret=0

  messageTitle "Prepare Amazon EFS Infrastructure"

  [ -z "$AWS_REGION" ]       && { echo "ERROR: AWS_REGION is not set"; exit 1; }
  [ -z "$EKS_CLUSTER_NAME" ] && { echo "ERROR: EKS_CLUSTER_NAME is not set"; exit 1; }

  # ------------------------------------------------------------------------
  # Get cluster VPC + subnets
  # ------------------------------------------------------------------------
  VPC_ID=$(aws eks describe-cluster \
    --name "$EKS_CLUSTER_NAME" \
    --region "$AWS_REGION" \
    --query 'cluster.resourcesVpcConfig.vpcId' \
    --output text 2>/tmp/error.log); ret=$?

  if [ $ret -ne 0 ] || [ -z "$VPC_ID" ] || [ "$VPC_ID" = "None" ]; then
    logMessages /tmp/error.log
    echo "ERROR: Failed to get VPC ID for cluster $EKS_CLUSTER_NAME"
    exit 1
  fi

  SUBNET_IDS=$(aws eks describe-cluster \
    --name "$EKS_CLUSTER_NAME" \
    --region "$AWS_REGION" \
    --query 'cluster.resourcesVpcConfig.subnetIds' \
    --output text 2>/tmp/error.log); ret=$?

  if [ $ret -ne 0 ] || [ -z "$SUBNET_IDS" ]; then
    logMessages /tmp/error.log
    echo "ERROR: Failed to get subnet IDs for cluster $EKS_CLUSTER_NAME"
    exit 1
  fi

  echo " ▪ VPC_ID ...............: $VPC_ID"
  echo " ▪ SUBNET_IDS ...........: $SUBNET_IDS"

  # ------------------------------------------------------------------------
  # Create / reuse EFS filesystem
  # ------------------------------------------------------------------------
  EFS_FILE_SYSTEM_ID=$(aws efs describe-file-systems \
    --region "$AWS_REGION" \
    --query "FileSystems[?Name=='$EFS_NAME'].FileSystemId | [0]" \
    --output text 2>/tmp/error.log); ret=$?

  if [ $ret -ne 0 ]; then
    logMessages /tmp/error.log
    echo "ERROR: Failed to query EFS file systems"
    exit 1
  fi

  if [ -z "$EFS_FILE_SYSTEM_ID" ] || [ "$EFS_FILE_SYSTEM_ID" = "None" ]; then
    echo " ▪ Create EFS filesystem : $EFS_NAME"

    EFS_FILE_SYSTEM_ID=$(aws efs create-file-system \
      --creation-token "$EFS_NAME" \
      --performance-mode generalPurpose \
      --encrypted \
      --tags Key=Name,Value="$EFS_NAME" \
      --region "$AWS_REGION" \
      --query 'FileSystemId' \
      --output text 2>/tmp/error.log); ret=$?

    if [ $ret -ne 0 ] || [ -z "$EFS_FILE_SYSTEM_ID" ] || [ "$EFS_FILE_SYSTEM_ID" = "None" ]; then
      logMessages /tmp/error.log
      echo "ERROR: Failed to create EFS filesystem"
      exit 1
    fi
  else
    echo " ▪ EFS filesystem exists : $EFS_FILE_SYSTEM_ID"
  fi

  # ------------------------------------------------------------------------
  # Create / reuse EFS security group
  # ------------------------------------------------------------------------
  EFS_SECURITY_GROUP_ID=$(aws ec2 describe-security-groups \
    --filters Name=vpc-id,Values="$VPC_ID" Name=group-name,Values="$EFS_SG_NAME" \
    --region "$AWS_REGION" \
    --query 'SecurityGroups[0].GroupId' \
    --output text 2>/tmp/error.log); ret=$?

  if [ -z "$EFS_SECURITY_GROUP_ID" ] || [ "$EFS_SECURITY_GROUP_ID" = "None" ]; then
    echo " ▪ Create EFS SG ........: $EFS_SG_NAME"

    EFS_SECURITY_GROUP_ID=$(aws ec2 create-security-group \
      --group-name "$EFS_SG_NAME" \
      --description "EFS Security Group for $EKS_CLUSTER_NAME" \
      --vpc-id "$VPC_ID" \
      --region "$AWS_REGION" \
      --query 'GroupId' \
      --output text 2>/tmp/error.log); ret=$?

    if [ $ret -ne 0 ] || [ -z "$EFS_SECURITY_GROUP_ID" ] || [ "$EFS_SECURITY_GROUP_ID" = "None" ]; then
      logMessages /tmp/error.log
      echo "ERROR: Failed to create EFS security group"
      exit 1
    fi

    aws ec2 authorize-security-group-ingress \
      --group-id "$EFS_SECURITY_GROUP_ID" \
      --protocol tcp \
      --port 2049 \
      --cidr 0.0.0.0/0 \
      --region "$AWS_REGION" > /tmp/error.log 2>&1; ret=$?

    if [ $ret -ne 0 ]; then
      logMessages /tmp/error.log
      echo "ERROR: Failed to authorize EFS security group ingress"
      exit 1
    fi
  else
    echo " ▪ EFS SG exists ........: $EFS_SECURITY_GROUP_ID"
  fi

  # ------------------------------------------------------------------------
  # Create mount target per AZ
  # ------------------------------------------------------------------------
  for subnet in $SUBNET_IDS; do
    subnetAzId=$(aws ec2 describe-subnets \
      --subnet-ids "$subnet" \
      --region "$AWS_REGION" \
      --query 'Subnets[0].AvailabilityZoneId' \
      --output text 2>/tmp/error.log); ret=$?

    if [ $ret -ne 0 ] || [ -z "$subnetAzId" ]; then
      logMessages /tmp/error.log
      echo "ERROR: Failed to get AZ ID for subnet $subnet"
      exit 1
    fi

    MT_ID=$(aws efs describe-mount-targets \
      --file-system-id "$EFS_FILE_SYSTEM_ID" \
      --region "$AWS_REGION" \
      --query "MountTargets[?AvailabilityZoneId=='$subnetAzId'].MountTargetId | [0]" \
      --output text 2>/tmp/error.log); ret=$?

    if [ $ret -ne 0 ]; then
      logMessages /tmp/error.log
      echo "ERROR: Failed to query mount targets"
      exit 1
    fi

    if [ -z "$MT_ID" ] || [ "$MT_ID" = "None" ]; then
      echo " ▪ Create mount target ..: $subnet ($subnetAzId)"

      aws efs create-mount-target \
        --file-system-id "$EFS_FILE_SYSTEM_ID" \
        --subnet-id "$subnet" \
        --security-groups "$EFS_SECURITY_GROUP_ID" \
        --region "$AWS_REGION" > /tmp/error.log 2>&1; ret=$?

      if [ $ret -ne 0 ]; then
        logMessages /tmp/error.log
        echo "ERROR: Failed to create mount target for subnet $subnet"
        exit 1
      fi
    else
      echo " ▪ Mount target exists ..: $subnet ($subnetAzId)"
    fi
  done

  {
    grep -v '^export EFS_FILE_SYSTEM_ID=' "$HOME/.faig.stat" 2>/dev/null | \
    grep -v '^export EFS_SECURITY_GROUP_ID='
    echo "export EFS_FILE_SYSTEM_ID=$EFS_FILE_SYSTEM_ID"
    echo "export EFS_SECURITY_GROUP_ID=$EFS_SECURITY_GROUP_ID"
  } > /tmp/faig.stat.$$ && mv /tmp/faig.stat.$$ "$HOME/.faig.stat"

  echo " ▪ EFS_FILE_SYSTEM_ID ...: $EFS_FILE_SYSTEM_ID"
  echo " ▪ EFS_SECURITY_GROUP_ID : $EFS_SECURITY_GROUP_ID"
}


# ------------------------------------------------------------------------------------------
# Function Name ......: installEFSCSIDriver
# Function Purpose ...: Install / upgrade AWS EFS CSI driver with IAM service account
# ------------------------------------------------------------------------------------------
# Dependencies .......: AWS_REGION, EKS_CLUSTER_NAME, AWS_PROFILE
# Optional Vars ......: EFS_CSI_NAMESPACE, EFS_CSI_SA_NAME, EFS_CSI_RELEASE
# ------------------------------------------------------------------------------------------
installEFSCSIDriver() {
  local EFS_CSI_DEPLOYMENT="${EFS_CSI_DEPLOYMENT:-efs-csi-controller}"
  local EFS_CSI_NAMESPACE="${EFS_CSI_NAMESPACE:-kube-system}"
  local EFS_CSI_SA_NAME="${EFS_CSI_SA_NAME:-efs-csi-controller-sa}"
  local EFS_CSI_RELEASE="${EFS_CSI_RELEASE:-aws-efs-csi-driver}"
  local EFS_POLICY_ARN="arn:aws:iam::aws:policy/service-role/AmazonEFSCSIDriverPolicy"
  local ROLE_ARN=""
  local ret=0

  messageTitle "Install Amazon EFS CSI Driver"

  [ -z "$AWS_REGION" ]       && { echo "ERROR: AWS_REGION is not set"; exit 1; }
  [ -z "$EKS_CLUSTER_NAME" ] && { echo "ERROR: EKS_CLUSTER_NAME is not set"; exit 1; }
  [ -z "$AWS_PROFILE" ]      && { echo "ERROR: AWS_PROFILE is not set"; exit 1; }

  ROLE_ARN=$(kubectl get sa "$EFS_CSI_SA_NAME" -n "$EFS_CSI_NAMESPACE" \
    -o jsonpath='{.metadata.annotations.eks\.amazonaws\.com/role-arn}' 2>/dev/null)

  if [ -z "$ROLE_ARN" ]; then
    echo " ▪ Create / update IAM SA : $EFS_CSI_SA_NAME"

    eksctl create iamserviceaccount \
      --cluster "$EKS_CLUSTER_NAME" \
      --namespace "$EFS_CSI_NAMESPACE" \
      --name "$EFS_CSI_SA_NAME" \
      --attach-policy-arn "$EFS_POLICY_ARN" \
      --approve \
      --region "$AWS_REGION" \
      --profile "$AWS_PROFILE" \
      --override-existing-serviceaccounts > /tmp/error.log 2>&1; ret=$?

    if [ $ret -ne 0 ]; then
      logMessages /tmp/error.log
      echo "ERROR: Failed to create/update IAM service account for EFS CSI driver"
      exit 1
    fi

    ROLE_ARN=$(kubectl get sa "$EFS_CSI_SA_NAME" -n "$EFS_CSI_NAMESPACE" \
      -o jsonpath='{.metadata.annotations.eks\.amazonaws\.com/role-arn}' 2>/dev/null)

    if [ -z "$ROLE_ARN" ]; then
      echo "ERROR: EFS CSI service account has no role annotation"
      exit 1
    fi
  else
    echo " ▪ IAM SA exists ........: $EFS_CSI_SA_NAME"
  fi

  echo " ▪ EFS CSI role ARN .....: $ROLE_ARN"

  helm repo add aws-efs-csi-driver https://kubernetes-sigs.github.io/aws-efs-csi-driver/ \
    >/tmp/error.log 2>&1 || true
  helm repo update >/tmp/error.log 2>&1; ret=$?

  if [ $ret -ne 0 ]; then
    logMessages /tmp/error.log
    echo "ERROR: Failed to update Helm repositories"
    exit 1
  fi

  echo " ▪ Install / upgrade ....: $EFS_CSI_RELEASE"
  helm upgrade --install "$EFS_CSI_RELEASE" aws-efs-csi-driver/aws-efs-csi-driver \
    -n "$EFS_CSI_NAMESPACE" \
    --set controller.serviceAccount.create=false \
    --set controller.serviceAccount.name="$EFS_CSI_SA_NAME" > /tmp/error.log 2>&1; ret=$?

  if [ $ret -ne 0 ]; then
    logMessages /tmp/error.log
    echo "ERROR: Failed to install/upgrade EFS CSI driver"
    exit 1
  fi

  kubectl rollout status deployment/efs-csi-controller \
    -n "$EFS_CSI_NAMESPACE" --timeout=180s > /tmp/error.log 2>&1; ret=$?

  if [ $ret -ne 0 ]; then
    logMessages /tmp/error.log
    echo "ERROR: EFS CSI driver rollout failed"
    exit 1
  fi

  echo " ▪ EFS CSI driver ready"
}


# ------------------------------------------------------------------------------------------
# Function Name ......: installEFSstorageClass
# Function Purpose ...: Create / update EFS StorageClass (shared or FortiAIGate dedicated)
# ------------------------------------------------------------------------------------------
# Dependencies .......: EFS_FILE_SYSTEM_ID, EFS_STORAGE_CLASS
# Optional Vars ......: EFS_MODE=[shared|faig]
# ------------------------------------------------------------------------------------------
installEFSstorageClass() {

  local EFS_MODE="${EFS_MODE:-faig}"
  local ret=0

  messageTitle "Install Amazon EFS StorageClass"

  [ -z "$EFS_FILE_SYSTEM_ID" ] && { echo "ERROR: EFS_FILE_SYSTEM_ID is not set"; exit 1; }
  [ -z "$EFS_STORAGE_CLASS" ]  && { echo "ERROR: EFS_STORAGE_CLASS is not set"; exit 1; }

  case "$EFS_MODE" in
    shared)
      cat > /tmp/efs-storageclass.yaml <<EOF
apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  name: $EFS_STORAGE_CLASS
provisioner: efs.csi.aws.com
parameters:
  provisioningMode: efs-ap
  fileSystemId: $EFS_FILE_SYSTEM_ID
  directoryPerms: "700"
reclaimPolicy: Delete
volumeBindingMode: Immediate
EOF
      ;;
    faig)
      cat > /tmp/efs-storageclass.yaml <<EOF
apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  name: $EFS_STORAGE_CLASS
provisioner: efs.csi.aws.com
parameters:
  provisioningMode: efs-ap
  fileSystemId: $EFS_FILE_SYSTEM_ID
  basePath: "/fortiaigate"
  directoryPerms: "770"
  uid: "1001"
  gid: "1001"
reclaimPolicy: Delete
volumeBindingMode: Immediate
EOF
      ;;
    *)
      echo "ERROR: Unsupported EFS_MODE '$EFS_MODE' (expected: shared or faig)"
      exit 1
      ;;
  esac

  echo " ▪ Apply StorageClass ....: $EFS_STORAGE_CLASS ($EFS_MODE)"
  kubectl apply -f /tmp/efs-storageclass.yaml > /tmp/error.log 2>&1; ret=$?

  if [ $ret -ne 0 ]; then
    logMessages /tmp/error.log
    echo "ERROR: Failed to apply EFS StorageClass"
    exit 1
  fi

  kubectl get storageclass "$EFS_STORAGE_CLASS"
}








