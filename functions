# ------------------------------------------------------------------------------------------
# Function Name ......: checkLocalConfig
# Function Purpose ...: Verify Installed CLI Utilities for Mac
# ------------------------------------------------------------------------------------------
# Argument ($1) ......: none
# Dependancies: ......: messageLine()
# ------------------------------------------------------------------------------------------
# Return Value .......: none
# ------------------------------------------------------------------------------------------
checkLocalConfig() {
  if [ -f $HOME/.faig.cfg ]; then 
    . $HOME/.faig.cfg

  # Make sure AWS Access credentials are set
  if [ -z "$AWS_PROFILE" ]; then
    echo "ERROR: AWS Access Credentials are not set in (\$HOME/.faig.cfg), please set them as follows: "
    echo '       export AWS_PROFILE="profile-name"'
    exit 1
  fi

  if [ -z "$AWS_REGION" ]; then 
    echo "ERROR: AWS Region is not configured in (\$HOME/.faig.cfg), please set them as follows: "
    echo '       export AWS_REGION=eu-north-1'
    exit 1
  fi

  if [ -z "$EKS_CLUSTER_NAME" ]; then 
    echo "ERROR: AWS Region is not configured in (\$HOME/.faig.cfg), please set them as follows: "
    echo '       export EKS_CLUSTER_NAME=\"eks-genai-fortiaigate\"'
    exit 1
  fi

  if [ -z "$ROUT53_DOMAIN" ]; then 
    echo "ERROR: AWS Region is not configured in (\$HOME/.faig.cfg), please set them as follows: "
    echo '       export ROUT53_DOMAIN=\"fortiaigate.fortidemo.ch\"'
    exit 1
  fi

  if [ -z "$FAID_LICENSE_DIR" ]; then 
    echo "ERROR: AWS Region is not configured in (\$HOME/.faig.cfg), please set them as follows: "
    echo '       export ROUT53_DOMAIN=\"fortiaigate.fortidemo.ch\"'
    exit 1
  fi

  else
    echo "ERROR: FortiAIgate Deployment Configu (\$HOME/.faig.cfg) not set"
    echo "       Please fill out the required parameters in the file"

    echo "export AWS_REGION=\"\""                       >  $HOME/.faig.cfg
    echo "EKS_CLUSTER_NAME=\"\""                        >> $HOME/.faig.cfg
    echo "EKS_ODMD_NG_NODES=1\"\""                      >> $HOME/.faig.cfg
    echo "EKS_SPOT_NG_NODES=3\"\""                      >> $HOME/.faig.cfg
    echo ""                                             >> $HOME/.faig.cfg
    echo "# AWS Access Credentials"                     >> $HOME/.faig.cfg
    echo "AWS_PROFILE=\"\""                             >> $HOME/.faig.cfg
    echo ""                                             >> $HOME/.faig.cfg
    echo "# AWS Rout54 Access Credentials"              >> $HOME/.faig.cfg
    echo "ROUT53_DNS_UPDATES=\"false\""                 >> $HOME/.faig.cfg
    echo "ROUT53_REGION=\"\""                           >> $HOME/.faig.cfg
    echo "ROUT53_ACCESS_KEY_ID=\"\""                    >> $HOME/.faig.cfg
    echo "ROUT53_SECRET_ACCESS_KEY=\"\""                >> $HOME/.faig.cfg
    echo "ROUT53_HOSTED_ZONE_ID=\"\""                   >> $HOME/.faig.cfg
    echo "ROUT53_DOMAIN=\"\""                           >> $HOME/.faig.cfg
    echo ""                                             >> $HOME/.faig.cfg
    echo "# FortiAiGate (FAIG) Configuration"           >> $HOME/.faig.cfg
    echo "FAID_LICENSE_DIR=\"\$HOME/.faid/licenses\""   >> $HOME/.faig.cfg
    echo ""                                             >> $HOME/.faig.cfg
    echo "# AWS RCR Repository Configuration"           >> $HOME/.faig.cfg
    echo "ECR_FORTIAIGATE_SOURCE_DIR=\"\""              >> $HOME/.faig.cfg
    echo "ECR_FORTIAIGATE_TAG=\"\""                     >> $HOME/.faig.cfg
    echo "ECR_REGION=\"\""                              >> $HOME/.faig.cfg
  fi
} 


# ------------------------------------------------------------------------------------------
# Function Name ......: logMessages
# Function Purpose ...: Verify Installed CLI Utilities for Mac
# ------------------------------------------------------------------------------------------
# Argument ($1) ......: none
# Dependancies: ......: messageLine()
# ------------------------------------------------------------------------------------------
# Return Value .......: none
# ------------------------------------------------------------------------------------------
logMessages() { 
  LOGFILE=$1
  messageLine 1>&2
  cat $LOGFILE 1>&2
  messageLine 1>&2
} 

# ------------------------------------------------------------------------------------------
# Function Name ......: messageLine
# Function Purpose ...: Print a Line on the Screen
# ------------------------------------------------------------------------------------------
# Argument ($1) ......: none
# Dependancies: ......: Environment Variable. COLUMNS # Wide of the Terminal
# ------------------------------------------------------------------------------------------
# Return Value .......: none
# ------------------------------------------------------------------------------------------
messageLine() {
  #echo "------------------------------------------------------------------------------------------------------------------------------------------------------------------"
  COL=120
  str="";n=0; while [ $n -lt $COL ]; do str="${str}-"; let n=n+1; done
  echo "$str"
}

# ------------------------------------------------------------------------------------------
# Function Name ......: verifyCLIutils
# Function Purpose ...: Verify Installed CLI Utilities for Mac
# ------------------------------------------------------------------------------------------
# Argument ($1) ......: none
# Dependancies: ......: 
#                     : 
# ------------------------------------------------------------------------------------------
# Return Value .......: none
# ------------------------------------------------------------------------------------------
verifyCLIutils() {
  MODE="$1"

  messageTitle "Verify Installed CLI Utilities"
  aws --version > /dev/null 2>&1; awscli=$?
  if [ $awscli -eq 0 ]; then
    echo " ▪ AWS CLI ............: $(aws --version | head -1)"
  else
    echo "ERROR: EKS CLI not installed"
    echo "       => brew install awscli"
  fi

  eksctl version > /dev/null 2>&1; ekscli=$?
  if [ $ekscli -eq 0 ]; then
    echo " ▪ EKS CLI ............: $(eksctl version | head -1)"
  else
    echo "ERROR: EKS CLI not installed"
    echo "       => brew tap weaveworks/tap"
    echo "       => brew install weaveworks/tap/eksctl"
    exit
  fi

  jq --version > /dev/null 2>&1; jqcli=$?
  if [ $ekscli -eq 0 ]; then
    echo " ▪ JQ .................: $(jq --version | head -1)"
  else
    echo "ERROR: JQ Utility not installed"
    echo "       => brew install jq"
    exit
  fi

  if [ "$MODE" == "deploy" ]; then 
    kubectl version --client >/dev/null 2>&1; ret=$?
    if [ $ret -eq 0 ]; then
      echo " ▪ Kubectl ............: $(kubectl version --client | head -1)"
    else
      echo "ERROR: kubectl Utility not installed"
      echo "       => brew install kubectl"
      exit
    fi

    helm version >/dev/null 2>&1; ret=$?
      if [ $ret -eq 0 ]; then
      echo " ▪ Helm ...............: $(helm version | awk -F',' '{ print $1 }' | sed -e 's/"//g' -e 's/version\.//g')"
    else
      echo "ERROR: helm Utility not installed"
      echo "       => brew install helm"
      exit
    fi
  fi

  if [ "$MODE" == "registry" ]; then 
     skopeo --version >/dev/null 2>&1; ret=$?
      if [ $ret -eq 0 ]; then
      echo " ▪ skopeo .............: $( skopeo --version)"
    else
      echo "ERROR: skopeo Utility not installed"
      echo "       => brew install skopeo"
      exit
    fi
  fi
}

messageTitle() {
  _msg="$*"
  _dat=$(date "+%Y%m%d-%H:%M:%S")
  
  [ $(uname) == "Linux" ] && HST="jump-host" || HST="localhost"

  if [ "${DEBUG}" == "1" ]; then
    if [ "$HST" == "localhost" ]; then
      #printf "\e[37m[${_dat}-$HST] ${_msg}\e[0m\n" 
      printf "\e[1m[${_dat}-$HST] ${_msg}\e[0m\n"
    else
      echo -e "[${_dat}-$HST] ${_msg}"
    fi
  else
    #printf "\e[37m[${_msg}\e[0m\n"
    printf "\e[1m${_msg}\e[0m\n"
    #echo -e "\e[1mBold${_msg}"
  fi
}

