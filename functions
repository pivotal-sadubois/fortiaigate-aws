installNVIDIAdevicePlugin() {
  echo " ▪ Install NVIDIA Device Plugin"
  kubectl apply -f https://raw.githubusercontent.com/NVIDIA/k8s-device-plugin/v0.17.0/deployments/static/nvidia-device-plugin.yml > /dev/null 2>&1; ret=$?

  echo "   ---------------------------------------------------------------------------------------------------------------------"
  kubectl get nodes -o custom-columns=NAME:.metadata.name,GPU:.status.allocatable.'nvidia\.com/gpu' | sed 's/^/   /g'
  echo "   ---------------------------------------------------------------------------------------------------------------------"
}

