# Function Name ......: deployApp
# Function Purpose ...: Deploy an application workload
# ------------------------------------------------------------------------------------------
# Argument ($1) ......: <app-name>
# Dependancies: ......:
# ------------------------------------------------------------------------------------------
# Return Value .......:
# ------------------------------------------------------------------------------------------
deployApp() {

  APP_NAME="$1"
  APP_NAMESPACE="$APP_NAME"
  APP_DEPLOYMENT="$APP_NAME"

  messageTitle "Deploy Application $APP_NAME"

  if [ -z "$APP_NAME" ]; then
    echo "ERROR: Missing arguments"
    echo "       => deployApp <app-name>"
    exit 1
  fi

  kubectl get namespace "$APP_NAMESPACE" >/dev/null 2>&1; ret=$?
  if [ $ret -ne 0 ]; then
    echo " ▪ Create Namespace ....: $APP_NAMESPACE"
    kubectl create namespace "$APP_NAMESPACE" > /tmp/error.log 2>&1; ret=$?
    if [ $ret -ne 0 ]; then
      logMessages /tmp/error.log
      echo "ERROR: Creating namespace failed"
      echo "       => kubectl create namespace $APP_NAMESPACE"
      exit 1
    fi
  else
    echo " ▪ Namespace already exists"
  fi

  if [ ! -f "files/${APP_NAME}.yaml" ]; then
    echo "ERROR: Application manifest not found"
    echo "       => files/${APP_NAME}.yaml"
    exit 1
  fi

  echo " ▪ Apply App Manifest ..: files/${APP_NAME}.yaml"
  kubectl apply -n "$APP_NAMESPACE" -f "files/${APP_NAME}.yaml" > /tmp/error.log 2>&1; ret=$?
  if [ $ret -ne 0 ]; then
    logMessages /tmp/error.log
    echo "ERROR: Deploying application failed"
    echo "       => kubectl apply -n $APP_NAMESPACE -f files/${APP_NAME}.yaml"
    exit 1
  fi

  echo " ▪ Waiting for Deployment to become ready..."
  kubectl -n "$APP_NAMESPACE" rollout status deployment/"$APP_DEPLOYMENT" --timeout=5m > /tmp/error.log 2>&1; ret=$?
