# ------------------------------------------------------------------------------------------
# Function Name ......: checkLocalConfig
# Function Purpose ...: Verify Installed CLI Utilities for Mac
# ------------------------------------------------------------------------------------------
# Argument ($1) ......: none
# Dependancies: ......: messageLine()
# ------------------------------------------------------------------------------------------
# Return Value .......: none
# ------------------------------------------------------------------------------------------
checkLocalConfig() {
  if [ -f $HOME/.fortiaigate.cfg ]; then 
    . $HOME/.fortiaigate.cfg

  # Make sure AWS Access credentials are set
  if [ -z "$AWS_ACCESS_KEY_ID" -o -z "$AWS_SECRET_ACCESS_KEY" -o -z "$AWS_SESSION_TOKEN" ]; then
    echo "ERROR: AWS Access Credentials are not set in (\$HOME/.fortiaigate.cfg), please set them as follows: "
    echo '       export AWS_ACCESS_KEY_ID="XXXXXXXXXXXXXXXXXXXX"'
    echo '       export AWS_SECRET_ACCESS_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"'
    echo '       export AWS_SESSION_TOKEN="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX..."'
    exit 1
  fi

  if [ -z "$AWS_REGION" ]; then 
    echo "ERROR: AWS Region is not configured in (\$HOME/.fortiaigate.cfg), please set them as follows: "
    echo '       export AWS_REGION=eu-north-1'
    exit 1
  fi

  if [ -z "$EKS_CLUSTER_NAME" ]; then 
    echo "ERROR: AWS Region is not configured in (\$HOME/.fortiaigate.cfg), please set them as follows: "
    echo '       export EKS_CLUSTER_NAME=\"eks-genai-fortiaigate\"'
    exit 1
  fi

  if [ -z "$ROUT53_DOMAIN" ]; then 
    echo "ERROR: AWS Region is not configured in (\$HOME/.fortiaigate.cfg), please set them as follows: "
    echo '       export ROUT53_DOMAIN=\"fortiaigate.fortidemo.ch\"'
    exit 1
  fi

  else
    echo "ERROR: FortiAIgate Deployment Configu (\$HOME/.fortiaigate.cfg) not set"
    echo "       Please fill out the required parameters in the file"

    echo "export AWS_REGION=\"\""                    >  $HOME/.fortiaigate.cfg
    echo "export EKS_CLUSTER_NAME=\"\""              >> $HOME/.fortiaigate.cfg
    echo "export EKS_CLUSTER_NAME=\"\""              >> $HOME/.fortiaigate.cfg
    echo ""                                          >> $HOME/.fortiaigate.cfg
    echo "# AWS Access Credentials"                  >> $HOME/.fortiaigate.cfg
    echo "AWS_ACCESS_KEY_ID=\"\""                    >> $HOME/.fortiaigate.cfg
    echo "AWS_SECRET_ACCESS_KEY=\"\""                >> $HOME/.fortiaigate.cfg
    echo "AWS_SESSION_TOKEN=\"\""                    >> $HOME/.fortiaigate.cfg
    echo ""                                          >> $HOME/.fortiaigate.cfg
    echo "# AWS Rout54 Access Credentials"           >> $HOME/.fortiaigate.cfg
    echo "ROUT53_DNS_UPDATES=\"false\""              >> $HOME/.fortiaigate.cfg
    echo "ROUT53_REGION=\"\""                        >> $HOME/.fortiaigate.cfg
    echo "ROUT53_ACCESS_KEY_ID=\"\""                 >> $HOME/.fortiaigate.cfg
    echo "ROUT53_SECRET_ACCESS_KEY=\"\""             >> $HOME/.fortiaigate.cfg
    echo "ROUT53_HOSTED_ZONE_ID=\"\""                >> $HOME/.fortiaigate.cfg
    echo "ROUT53_DOMAIN=\"\""                        >> $HOME/.fortiaigate.cfg
  fi
} 


# ------------------------------------------------------------------------------------------
# Function Name ......: logMessages
# Function Purpose ...: Verify Installed CLI Utilities for Mac
# ------------------------------------------------------------------------------------------
# Argument ($1) ......: none
# Dependancies: ......: messageLine()
# ------------------------------------------------------------------------------------------
# Return Value .......: none
# ------------------------------------------------------------------------------------------
logMessages() { 
  LOGFILE=$1
  messageLine 1>&2
  cat $LOGFILE 1>&2
  messageLine 1>&2
} 

# ------------------------------------------------------------------------------------------
# Function Name ......: messageLine
# Function Purpose ...: Print a Line on the Screen
# ------------------------------------------------------------------------------------------
# Argument ($1) ......: none
# Dependancies: ......: Environment Variable. COLUMNS # Wide of the Terminal
# ------------------------------------------------------------------------------------------
# Return Value .......: none
# ------------------------------------------------------------------------------------------
messageLine() {
  #echo "------------------------------------------------------------------------------------------------------------------------------------------------------------------"
  str="";n=0; while [ $n -lt $COLUMNS ]; do str="${str}-"; let n=n+1; done
 echo "$str"
}

# ------------------------------------------------------------------------------------------
# Function Name ......: verifyCLIutils
# Function Purpose ...: Verify Installed CLI Utilities for Mac
# ------------------------------------------------------------------------------------------
# Argument ($1) ......: none
# Dependancies: ......: 
#                     : 
# ------------------------------------------------------------------------------------------
# Return Value .......: none
# ------------------------------------------------------------------------------------------
verifyCLIutils() {
  messageTitle "Verify Installed CLI Utilities"
  aws --version > /dev/null 2>&1; awscli=$?
  if [ $awscli -eq 0 ]; then
    echo " ▪ AWS CLI ............: $(aws --version | head -1)"
  else
    echo "ERROR: EKS CLI not installed"
    echo "       => brew install awscli"
  fi

  eksctl version > /dev/null 2>&1; ekscli=$?
  if [ $ekscli -eq 0 ]; then
    echo " ▪ EKS CLI ............: $(eksctl version | head -1)"
  else
    echo "ERROR: EKS CLI not installed"
    echo "       => brew tap weaveworks/tap"
    echo "       => brew install weaveworks/tap/eksctl"
    exit
  fi

  jq --version > /dev/null 2>&1; jqcli=$?
  if [ $ekscli -eq 0 ]; then
    echo " ▪ JQ .................: $(jq --version | head -1)"
  else
    echo "ERROR: JQ Utility not installed"
    echo "       => brew install jq"
    exit
  fi

  kubectl version --client >/dev/null 2>&1; ret=$?
  if [ $ret -eq 0 ]; then
    echo " ▪ Kubectl ............: $(kubectl version --client | head -1)"
  else
    echo "ERROR: kubectl Utility not installed"
    echo "       => brew install kubectl"
    exit
  fi

}

messageTitle() {
  _msg="$*"
  _dat=$(date "+%Y%m%d-%H:%M:%S")
  
  [ $(uname) == "Linux" ] && HST="jump-host" || HST="localhost"

  if [ "${PCF_DEPLOYMENT_DEBUG}" == "true" -o "${DEBUG}" == "1" ]; then
    if [ "$HST" == "localhost" ]; then
      #printf "\e[37m[${_dat}-$HST] ${_msg}\e[0m\n" 
      printf "\e[1m[${_dat}-$HST] ${_msg}\e[0m\n"
    else
      echo -e "[${_dat}-$HST] ${_msg}"
    fi
  else
    #printf "\e[37m[${_msg}\e[0m\n"
    printf "\e[1m${_msg}\e[0m\n"
    #echo -e "\e[1mBold${_msg}"
  fi
}

# ------------------------------------------------------------------------------------------
