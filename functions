deployAppIngress() {

  APP_NAME="$1"
  APP_NAMESPACE="$APP_NAME"
  APP_INGRESS="${APP_NAME}-ingress"
  APP_FQDN="$2"

  messageTitle "Deploy ALB Ingress for Application $APP_NAME"

  if [ -z "$APP_NAME" -o -z "$APP_FQDN" ]; then
    echo "ERROR: Missing arguments"
    echo "       => deployAppIngress <app-name> <fqdn>"
    exit 1
  fi

  CERT_ARN=$(getCertARN "*.fortiaigate.fortidemo.ch")
  ret=$?
  if [ $ret -ne 0 -o -z "$CERT_ARN" ]; then
    echo "ERROR: Failed to get Certificate ARN"
    echo "       => getCertARN \"*.fortiaigate.fortidemo.ch\""
    exit 1
  fi

  echo " ▪ APP_NAME ............: $APP_NAME"
  echo " ▪ APP_NAMESPACE .......: $APP_NAMESPACE"
  echo " ▪ APP_INGRESS .........: $APP_INGRESS"
  echo " ▪ APP_FQDN ............: $APP_FQDN"
  echo " ▪ CERT_ARN ............: $CERT_ARN"

  sed \
    -e "s|XXX_APP_NAME_XXX|$APP_NAME|g" \
    -e "s|XXX_APP_NAMESPACE_XXX|$APP_NAMESPACE|g" \
    -e "s|XXX_APP_INGRESS_XXX|$APP_INGRESS|g" \
    -e "s|XXX_APP_FQDN_XXX|$APP_FQDN|g" \
    -e "s|XXX_ARN_XXX|$CERT_ARN|g" \
    files/app-ingress-template.yaml > /tmp/${APP_NAME}-ingress.yaml

  echo " ▪ Apply Ingress .......: /tmp/${APP_NAME}-ingress.yaml"
  kubectl apply -f /tmp/${APP_NAME}-ingress.yaml > /tmp/error.log 2>&1; ret=$?
  if [ $ret -ne 0 ]; then
    logMessages /tmp/error.log
    echo "ERROR: Applying ingress failed"
    echo "       => kubectl apply -f /tmp/${APP_NAME}-ingress.yaml"
    exit 1
  fi

  echo " ▪ Waiting for Ingress Address..."
  n=0
  while [ $n -lt 30 ]; do
    ALB_HOSTNAME=$(kubectl -n "$APP_NAMESPACE" get ingress "$APP_INGRESS" \
      -o jsonpath='{.status.loadBalancer.ingress[0].hostname}' 2>/tmp/error.log)
    [ -n "$ALB_HOSTNAME" ] && break
    sleep 10
    let n=n+1
  done

  if [ -z "$ALB_HOSTNAME" ]; then
    logMessages /tmp/error.log
    echo "ERROR: Failed to get ALB hostname from ingress"
    echo "       => kubectl -n $APP_NAMESPACE get ingress $APP_INGRESS -o jsonpath='{.status.loadBalancer.ingress[0].hostname}'"
    exit 1
  fi

  echo " ▪ ALB_HOSTNAME ........: $ALB_HOSTNAME"
}

# ------------------------------------------------------------------------------------------
# Function Name ......: testAppDNS
# Function Purpose ...: Test DNS and HTTP/HTTPS access for an application
# ------------------------------------------------------------------------------------------
# Argument ($1) ......: <fqdn>
# ------------------------------------------------------------------------------------------
testAppDNS() {

  APP_FQDN="$1"

  messageTitle "Test Application DNS and Connectivity"

  if [ -z "$APP_FQDN" ]; then
    echo "ERROR: Missing arguments"
    echo "       => testAppDNS <fqdn>"
    exit 1
  fi

  echo " ▪ Waiting for public DNS propagation..."
  n=0
  while [ $n -lt 30 ]; do
    nslookup "$APP_FQDN" 8.8.8.8 >/tmp/error.log 2>&1; ret=$?
    if [ $ret -eq 0 ]; then
      break
    fi
    sleep 10
    let n=n+1
  done

  if [ $ret -ne 0 ]; then
    logMessages /tmp/error.log
    echo "ERROR: DNS record not yet resolvable via public DNS"
    echo "       => nslookup $APP_FQDN 8.8.8.8"
    exit 1
  fi

  echo " ▪ HTTP Test ...........: http://$APP_FQDN"
  curl -I --max-time 10 "http://$APP_FQDN" > /tmp/error.log 2>/dev/null; ret=$?
  if [ $ret -ne 0 ]; then
    logMessages /tmp/error.log
    echo "ERROR: HTTP test failed"
    echo "       => curl -I --max-time 10 http://$APP_FQDN"
    exit 1
  fi
  cat /tmp/error.log

  echo " ▪ HTTPS Test ..........: https://$APP_FQDN"
  curl -I --max-time 10 "https://$APP_FQDN" > /tmp/error.log 2>/dev/null; ret=$?
  if [ $ret -ne 0 ]; then
    logMessages /tmp/error.log
    echo "ERROR: HTTPS test failed"
    echo "       => curl -I --max-time 10 https://$APP_FQDN"
    exit 1
  fi
  cat /tmp/error.log
}

# ------------------------------------------------------------------------------------------
# Function Name ......: installEFSstorageClass
# Function Purpose ...: Install Amazon EFS CSI driver and RWX StorageClass for EKS
# ------------------------------------------------------------------------------------------
# Argument ($1) ......:
# Dependancies: ......: AWS_REGION, EKS_CLUSTER_NAME, EFS_STORAGE_CLASS
# ------------------------------------------------------------------------------------------
# Return Value .......:
# ------------------------------------------------------------------------------------------
installEFSstorageClass() {

  EFS_ADDON_NAME="aws-efs-csi-driver"

  messageTitle "Amazon EFS RWX Storage for EKS Kubernetes Cluster"

  # ----------------------------------------------------------------------------------------
  # Check whether the EFS CSI addon is already installed
  # ----------------------------------------------------------------------------------------
  ADDON_STATUS=$(aws eks describe-addon \
    --cluster-name "$EKS_CLUSTER_NAME" \
    --addon-name "$EFS_ADDON_NAME" \
    --region "$AWS_REGION" \
    --query 'addon.status' \
    --output text 2>/tmp/error.log); ret=$?

  if [ $ret -ne 0 ]; then
    echo " ▪ Install EFS CSI addon .: $EFS_ADDON_NAME"

    eksctl create addon \
      --name "$EFS_ADDON_NAME" \
      --cluster "$EKS_CLUSTER_NAME" \
      --region "$AWS_REGION" \
      --force > /tmp/error.log 2>&1; ret=$?

    if [ $ret -ne 0 ]; then
      logMessages /tmp/error.log
      echo "ERROR: Installing EFS CSI addon failed"
      echo "       => eksctl create addon --name $EFS_ADDON_NAME --cluster $EKS_CLUSTER_NAME --region $AWS_REGION --force"
      exit 1
    fi
  else
    echo " ▪ EFS CSI addon already installed with status ($ADDON_STATUS)"
  fi

  # ----------------------------------------------------------------------------------------
  # Wait until addon becomes ACTIVE
  # ----------------------------------------------------------------------------------------
  echo " ▪ Waiting for EFS CSI addon to become ACTIVE..."
  while true; do
    ADDON_STATUS=$(aws eks describe-addon \
      --cluster-name "$EKS_CLUSTER_NAME" \
      --addon-name "$EFS_ADDON_NAME" \
      --region "$AWS_REGION" \
      --query 'addon.status' \
      --output text 2>/tmp/error.log); ret=$?

    if [ $ret -ne 0 ]; then
      logMessages /tmp/error.log
      echo "ERROR: Failed to read EFS CSI addon status"
      exit 1
    fi

    echo " ▪ EFS CSI addon status .: $ADDON_STATUS"
    [ "$ADDON_STATUS" = "ACTIVE" ] && break
    sleep 10
  done

  # ----------------------------------------------------------------------------------------
  # Get VPC ID and Subnet IDs from the EKS cluster
  # ----------------------------------------------------------------------------------------
  VPC_ID=$(aws eks describe-cluster \
    --name "$EKS_CLUSTER_NAME" \
    --region "$AWS_REGION" \
    --query 'cluster.resourcesVpcConfig.vpcId' \
    --output text 2>/tmp/error.log); ret=$?

  if [ $ret -ne 0 -o -z "$VPC_ID" ]; then
    logMessages /tmp/error.log
    echo "ERROR: Failed to get VPC ID for cluster $EKS_CLUSTER_NAME"
    exit 1
  fi

  SUBNET_IDS=$(aws eks describe-cluster \
    --name "$EKS_CLUSTER_NAME" \
    --region "$AWS_REGION" \
    --query 'cluster.resourcesVpcConfig.subnetIds' \
    --output text 2>/tmp/error.log); ret=$?

  if [ $ret -ne 0 -o -z "$SUBNET_IDS" ]; then
    logMessages /tmp/error.log
    echo "ERROR: Failed to get subnet IDs for cluster $EKS_CLUSTER_NAME"
    exit 1
  fi

  echo " ▪ VPC_ID ..............: $VPC_ID"
  echo " ▪ SUBNET_IDS ..........: $SUBNET_IDS"

  # ----------------------------------------------------------------------------------------
  # Check whether an EFS file system already exists for this cluster
  # ----------------------------------------------------------------------------------------
  EFS_FILE_SYSTEM_ID=$(aws efs describe-file-systems \
    --region "$AWS_REGION" \
    --output json 2>/tmp/error.log | jq -r --arg key "$EKS_CLUSTER_NAME" '
      .FileSystems[]
      | select(.Name == ("efs-" + $key))
      | .FileSystemId
    ' | head -1); ret=$?

  if [ $ret -ne 0 ]; then
    logMessages /tmp/error.log
    echo "ERROR: Failed to query existing EFS filesystems"
    exit 1
  fi

  if [ -z "$EFS_FILE_SYSTEM_ID" ]; then
    echo " ▪ Create EFS filesystem"

    EFS_FILE_SYSTEM_ID=$(aws efs create-file-system \
      --creation-token "efs-$EKS_CLUSTER_NAME" \
      --performance-mode generalPurpose \
      --encrypted \
      --tags Key=Name,Value="efs-$EKS_CLUSTER_NAME" \
      --region "$AWS_REGION" \
      --query 'FileSystemId' \
      --output text 2>/tmp/error.log); ret=$?

    if [ $ret -ne 0 -o -z "$EFS_FILE_SYSTEM_ID" ]; then
      logMessages /tmp/error.log
      echo "ERROR: Creating EFS filesystem failed"
      exit 1
    fi
  else
    echo " ▪ EFS filesystem already exists"
  fi

  echo " ▪ EFS_FILE_SYSTEM_ID ..: $EFS_FILE_SYSTEM_ID"

  # ----------------------------------------------------------------------------------------
  # Create / Reuse Security Group for EFS
  # ----------------------------------------------------------------------------------------
  EFS_SECURITY_GROUP_ID=$(aws ec2 describe-security-groups \
    --filters Name=vpc-id,Values="$VPC_ID" Name=group-name,Values="efs-$EKS_CLUSTER_NAME-sg" \
    --region "$AWS_REGION" \
    --query 'SecurityGroups[0].GroupId' \
    --output text 2>/tmp/error.log); ret=$?

  if [ "$EFS_SECURITY_GROUP_ID" = "None" -o -z "$EFS_SECURITY_GROUP_ID" ]; then
    echo " ▪ Create EFS Security Group"

    EFS_SECURITY_GROUP_ID=$(aws ec2 create-security-group \
      --group-name "efs-$EKS_CLUSTER_NAME-sg" \
      --description "EFS Security Group for $EKS_CLUSTER_NAME" \
      --vpc-id "$VPC_ID" \
      --region "$AWS_REGION" \
      --query 'GroupId' \
      --output text 2>/tmp/error.log); ret=$?

    if [ $ret -ne 0 -o -z "$EFS_SECURITY_GROUP_ID" ]; then
      logMessages /tmp/error.log
      echo "ERROR: Creating EFS Security Group failed"
      exit 1
    fi

    aws ec2 authorize-security-group-ingress \
      --group-id "$EFS_SECURITY_GROUP_ID" \
      --protocol tcp \
      --port 2049 \
      --cidr 0.0.0.0/0 \
      --region "$AWS_REGION" > /tmp/error.log 2>&1; ret=$?

    if [ $ret -ne 0 ]; then
      logMessages /tmp/error.log
      echo "ERROR: Authorizing EFS Security Group ingress failed"
      exit 1
    fi
  else
    echo " ▪ EFS Security Group already exists"
  fi

  echo " ▪ EFS_SECURITY_GROUP_ID: $EFS_SECURITY_GROUP_ID"

  # ----------------------------------------------------------------------------------------
  # Create mount targets in cluster Availability Zones
  # Only one mount target per Availability Zone is allowed
  # ----------------------------------------------------------------------------------------
  for subnet in $SUBNET_IDS; do

    subnetAzId=$(aws ec2 describe-subnets \
      --subnet-ids "$subnet" \
      --region "$AWS_REGION" \
      --query 'Subnets[0].AvailabilityZoneId' \
      --output text 2>/tmp/error.log); ret=$?

    if [ $ret -ne 0 -o -z "$subnetAzId" ]; then
      logMessages /tmp/error.log
      echo "ERROR: Failed to get Availability Zone ID for subnet $subnet"
      exit 1
    fi

    MT_ID=$(aws efs describe-mount-targets \
      --file-system-id "$EFS_FILE_SYSTEM_ID" \
      --region "$AWS_REGION" \
      --output json 2>/tmp/error.log | jq -r --arg azid "$subnetAzId" '
        .MountTargets[]
        | select(.AvailabilityZoneId == $azid)
        | .MountTargetId
      ' | head -1); ret=$?

    if [ $ret -ne 0 ]; then
      logMessages /tmp/error.log
      echo "ERROR: Failed to query EFS mount targets"
      exit 1
    fi

    if [ -z "$MT_ID" ]; then
      echo " ▪ Create mount target ..: $subnet ($subnetAzId)"

      aws efs create-mount-target \
        --file-system-id "$EFS_FILE_SYSTEM_ID" \
        --subnet-id "$subnet" \
        --security-groups "$EFS_SECURITY_GROUP_ID" \
        --region "$AWS_REGION" > /tmp/error.log 2>&1; ret=$?

      if [ $ret -ne 0 ]; then
        logMessages /tmp/error.log
        echo "ERROR: Creating EFS mount target failed for subnet $subnet"
        exit 1
      fi
    else
      echo " ▪ Mount target exists ..: $subnet ($subnetAzId)"
    fi
  done

  # ----------------------------------------------------------------------------------------
  # Create / Update StorageClass
  # ----------------------------------------------------------------------------------------
  cat > /tmp/efs-storageclass.yaml <<EOF
apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  name: $EFS_STORAGE_CLASS
provisioner: efs.csi.aws.com
parameters:
  provisioningMode: efs-ap
  fileSystemId: $EFS_FILE_SYSTEM_ID
  directoryPerms: "700"
reclaimPolicy: Delete
volumeBindingMode: Immediate
EOF

  echo " ▪ Apply StorageClass ...: $EFS_STORAGE_CLASS"
  kubectl apply -f /tmp/efs-storageclass.yaml > /tmp/error.log 2>&1; ret=$?

  if [ $ret -ne 0 ]; then
    logMessages /tmp/error.log
    echo "ERROR: Applying EFS StorageClass failed"
    exit 1
  fi

  echo " ▪  Write EFS configuration to state file (\$HOME/.faig.stat)"
  echo "export EFS_FILE_SYSTEM_ID=$EFS_FILE_SYSTEM_ID"    >> $HOME/.faig.stat
  echo "export EFS_SECURITY_GROUP_ID=$EFS_SECURITY_GROUP_ID" >> $HOME/.faig.stat

  echo " ▪ EFS RWX StorageClass installed successfully"
  kubectl get storageclass "$EFS_STORAGE_CLASS"
}

# ------------------------------------------------------------------------------------------
# Function Name ......: deleteEFSstorage
# Function Purpose ...: Delete EFS Storage
# ------------------------------------------------------------------------------------------
# Argument ($1) ......:
# Dependancies: ......: AWS_REGION, EKS_CLUSTER_NAME
# ------------------------------------------------------------------------------------------
# Return Value .......:
# ------------------------------------------------------------------------------------------
deleteEFSstorage() {
  EFS_NAME="efs-$EKS_CLUSTER_NAME"

  echo " ▪ checking Amazon EFS resources"

  EFS_FILE_SYSTEM_ID=$(aws efs describe-file-systems \
    --region "$AWS_REGION" \
    --output json 2>/dev/null | jq -r --arg key "$EFS_NAME" '
      .FileSystems[]
      | select(.Name == $key)
      | .FileSystemId
    ' | head -1)

  if [ -z "$EFS_FILE_SYSTEM_ID" ]; then
    echo " ▪ Amazon EFS already deleted"
    return
  fi

  echo " ▪ deleting Amazon EFS FileSystem ($EFS_FILE_SYSTEM_ID)"

  aws efs describe-access-points \
    --file-system-id "$EFS_FILE_SYSTEM_ID" \
    --region "$AWS_REGION" \
    > /tmp/efs-ap.json 2>/dev/null

  for ap in $(jq -r '.AccessPoints[]? | .AccessPointId' /tmp/efs-ap.json); do
    echo "   ▪ delete EFS Access Point ($ap)"
    aws efs delete-access-point \
      --access-point-id "$ap" \
      --region "$AWS_REGION" > /tmp/error.log 2>&1; ret=$?
    if [ $ret -ne 0 ]; then
      logMessages /tmp/error.log
      echo "ERROR: failed to delete EFS Access Point ($ap)"
      exit 1
    fi
  done

  while true; do
    aws efs describe-access-points \
      --file-system-id "$EFS_FILE_SYSTEM_ID" \
      --region "$AWS_REGION" \
      > /tmp/efs-ap.json 2>/dev/null

    apLeft=$(jq -r '[.AccessPoints[]?] | length' /tmp/efs-ap.json)
    [ "$apLeft" == "0" ] && break

    sleep 10
  done

  aws efs describe-mount-targets \
    --file-system-id "$EFS_FILE_SYSTEM_ID" \
    --region "$AWS_REGION" \
    > /tmp/efs-mt.json 2>/dev/null

  for mt in $(jq -r '.MountTargets[]? | .MountTargetId' /tmp/efs-mt.json); do
    echo "   ▪ delete EFS Mount Target ($mt)"
    aws efs delete-mount-target \
      --mount-target-id "$mt" \
      --region "$AWS_REGION" > /tmp/error.log 2>&1; ret=$?
    if [ $ret -ne 0 ]; then
      logMessages /tmp/error.log
      echo "ERROR: failed to delete EFS Mount Target ($mt)"
      exit 1
    fi
  done

  while true; do
    aws efs describe-mount-targets \
      --file-system-id "$EFS_FILE_SYSTEM_ID" \
      --region "$AWS_REGION" \
      > /tmp/efs-mt.json 2>/dev/null

    mtLeft=$(jq -r '[.MountTargets[]?] | length' /tmp/efs-mt.json)
    [ "$mtLeft" == "0" ] && break

    sleep 10
  done

  aws efs delete-file-system \
    --file-system-id "$EFS_FILE_SYSTEM_ID" \
    --region "$AWS_REGION" > /tmp/error.log 2>&1; ret=$?

  if [ $ret -ne 0 ]; then
    logMessages /tmp/error.log
    echo "ERROR: failed to delete EFS FileSystem ($EFS_FILE_SYSTEM_ID)"
    exit 1
  fi

  while true; do
    aws efs describe-file-systems \
      --file-system-id "$EFS_FILE_SYSTEM_ID" \
      --region "$AWS_REGION" >/dev/null 2>&1
    [ $? -ne 0 ] && break
    sleep 10
  done

  echo " ▪ Amazon EFS successfully deleted"
}

# ------------------------------------------------------------------------------------------
# Function Name ......: deleteEKSnodeGroup
# Function Purpose ...: Delete EFS NodeGroup
# ------------------------------------------------------------------------------------------
# Argument ($1) ......:
# Dependancies: ......: AWS_REGION, EKS_CLUSTER_NAME
# ------------------------------------------------------------------------------------------
# Return Value .......:
# ------------------------------------------------------------------------------------------
deleteEKSnodeGroup() {
  nodegroup=$(aws eks list-nodegroups  --cluster-name $EKS_CLUSTER_NAME --region $AWS_REGION  --no-cli-pager 2>/dev/null | jq -r '.nodegroups[]')
  if [ "$nodegroup" == "gpu-ondemand-ng" -o "$nodegroup" == "gpu-spot-ng"  ]; then
    echo " ▪ deleting EKS NodeGroup ($nodegroup)"
  
    eksctl delete nodegroup \
      --cluster $EKS_CLUSTER_NAME \
      --name $nodegroup \
      --disable-eviction \
      --profile "$AWS_PROFILE" \
      --region $AWS_REGION > /tmp/error.log 2>&1; ret=$?

    if [ $ret -ne 0 ]; then
      logMessages /tmp/error.log
      echo "ERROR: failed to delete NodeGroup"
      echo "       => eksctl delete nodegroup --name $nodegroup --region $AWS_REGION"
      exit
    fi

    NODEGROUP="$EKS_CLUSTER_NAME"

    while true; do
      status=$(aws eks describe-nodegroup \
        --cluster-name "$EKS_CLUSTER_NAME" \
        --nodegroup-name "$NODEGROUP" \
        --region "$AWS_REGION" \
        --query 'nodegroup.status' \
        --output text 2>/dev/null)
  
      if [ $? -ne 0 ]; then
        break
      fi
  
      sleep 15
    done
  else
    echo " ▪ EKS NodeGroup already deleted"
  fi
}

# ------------------------------------------------------------------------------------------
# Function Name ......: deleteELBv2LoadBalancer
# Function Purpose ...: Delete ELBv2 Load Balancer
# ------------------------------------------------------------------------------------------
# Argument ($1) ......:
# Dependancies: ......: AWS_REGION, EKS_CLUSTER_NAME
# ------------------------------------------------------------------------------------------
# Return Value .......:
# ------------------------------------------------------------------------------------------
deleteELBv2LoadBalancer() {
  LB_ARN=$(aws elbv2 describe-load-balancers --region $AWS_REGION | jq -r '.LoadBalancers[].LoadBalancerArn')
  if [ "$LB_ARN" != "" ]; then
    echo " ▪ deleting ALB Load Balancer ($LB_ARN)"
    aws elbv2 delete-load-balancer --load-balancer-arn "$LB_ARN" --region $AWS_REGION > /tmp/error.log 2>&1; ret=$?
    if [ $ret -ne 0 ]; then
      logMessages /tmp/error.log
      echo "ERROR: failed to delete load-balancer"
      echo "       => aws elbv2 delete-load-balancer --load-balancer-arn "$LB_ARN" --region $AWS_REGION"
      exit
    fi
  
    while aws elbv2 describe-load-balancers \
      --load-balancer-arns "$LB_ARN" \
      --region eu-north-1 >/dev/null 2>&1; do
      sleep 10
    done
  else 
    echo " ▪ ALB Load Balancer allredy deleted"
  fi
}

# ------------------------------------------------------------------------------------------
# Function Name ......: deleteEKScluster
# Function Purpose ...: Delete EKS Cluster
# ------------------------------------------------------------------------------------------
# Argument ($1) ......:
# Dependancies: ......: AWS_REGION, EKS_CLUSTER_NAME
# ------------------------------------------------------------------------------------------
# Return Value .......:
# ------------------------------------------------------------------------------------------
deleteEKScluster() {
  cluster=$(aws eks list-clusters --region $AWS_REGION 2>/dev/null | jq --arg key "$EKS_CLUSTER_NAME" -r '.clusters[] | select(. == $key)')
  if [ "$cluster" == "$EKS_CLUSTER_NAME" ]; then
    echo " ▪ deleting EKS Cluster ($EKS_CLUSTER_NAME)"
  
    eksctl delete cluster --name "$EKS_CLUSTER_NAME" --region $AWS_REGION --profile $AWS_PROFILE > /tmp/error.log 2>&1; ret=$?
    if [ $ret -ne 0 ]; then
      logMessages /tmp/error.log
      echo "ERROR: failed to delete the EKS Cluster"
      echo "       =>  eksctl delete cluster --name $EKS_CLUSTER_NAME --region $AWS_REGION --profile $AWS_PROFILE"
      exit
    fi
  
    while aws eks describe-cluster --name "$EKS_CLUSTER_NAME" \
      --region "$AWS_REGION" \
      --query 'cluster.status' \
      --output text >/dev/null 2>&1; do
      sleep 20
    done
  
    echo " ▪ EKS Cluster ($EKS_CLUSTER_NAME) sucessfuly deleted"
  else
    echo " ▪ EKS Cluster ($EKS_CLUSTER_NAME) already deleted"
  fi
}

# ------------------------------------------------------------------------------------------
# Function Name ......: waitForVpcResourcesToSettle
# Function Purpose ...: Wait until ALB/NAT related VPC resources have settled
# ------------------------------------------------------------------------------------------
# Argument ($1) ......: none
# Dependancies: ......: AWS_REGION, EKS_CLUSTER_NAME
# ------------------------------------------------------------------------------------------
# Return Value .......: none
# ------------------------------------------------------------------------------------------
waitForVpcResourcesToSettle() {

  VPC_ID=$(aws eks describe-cluster \
    --name "$EKS_CLUSTER_NAME" \
    --region "$AWS_REGION" \
    --query 'cluster.resourcesVpcConfig.vpcId' \
    --output text 2>/dev/null); ret=$?

  if [ $ret -ne 0 -o -z "$VPC_ID" -o "$VPC_ID" = "None" ]; then
    echo " ▪ VPC already unavailable, skipping settle wait"
    return
  fi

  echo " ▪ Waiting for VPC resources to settle ($VPC_ID)"

  # Proactively delete VPC dependencies to prevent CloudFormation stalls on VPC deletion
  deleteNatGatewaysInVpc "$VPC_ID"
  deleteAvailableNetworkInterfacesInVpc "$VPC_ID"
  deleteNonDefaultSecurityGroupsInVpc "$VPC_ID"

  n=0
  while [ $n -lt 40 ]; do

    eniCount=$(aws ec2 describe-network-interfaces \
      --region "$AWS_REGION" \
      --filters Name=vpc-id,Values="$VPC_ID" \
      --query 'length(NetworkInterfaces[])' \
      --output text 2>/dev/null)
    [ -z "$eniCount" -o "$eniCount" = "None" ] && eniCount=0

    natCount=$(aws ec2 describe-nat-gateways \
      --region "$AWS_REGION" \
      --filter Name=vpc-id,Values="$VPC_ID" \
      --query 'length(NatGateways[?State!=`deleted`])' \
      --output text 2>/dev/null)
    [ -z "$natCount" -o "$natCount" = "None" ] && natCount=0

    lbCount=$(aws elbv2 describe-load-balancers \
      --region "$AWS_REGION" \
      --query "length(LoadBalancers[?VpcId=='$VPC_ID'])" \
      --output text 2>/dev/null)
    [ -z "$lbCount" -o "$lbCount" = "None" ] && lbCount=0

    echo "   ▪ ENIs:$eniCount NAT:$natCount ELBv2:$lbCount"

    # LBs and NAT gateways must both be gone before cluster deletion
    [ "$lbCount" = "0" -a "$natCount" = "0" ] && break

    sleep 15
    let n=n+1
  done
}

# ------------------------------------------------------------------------------------------
# Function Name ......: waitForClusterStackDeletion
# Function Purpose ...: Wait until the cluster CloudFormation stack is deleted or failed
# ------------------------------------------------------------------------------------------
# Argument ($1) ......: none
# Dependancies: ......: AWS_REGION, EKS_CLUSTER_NAME
# ------------------------------------------------------------------------------------------
# Return Value .......: none
# ------------------------------------------------------------------------------------------
waitForClusterStackDeletion() {

  CLUSTER_STACK="eksctl-${EKS_CLUSTER_NAME}-cluster"

  echo " ▪ Waiting for CloudFormation cluster stack ($CLUSTER_STACK)"

  while true; do
    STACK_STATUS=$(aws cloudformation describe-stacks \
      --stack-name "$CLUSTER_STACK" \
      --region "$AWS_REGION" \
      --query 'Stacks[0].StackStatus' \
      --output text 2>/dev/null)
    ret=$?

    if [ $ret -ne 0 ]; then
      echo " ▪ CloudFormation stack already deleted"
      break
    fi

    echo " ▪ Stack Status ........: $STACK_STATUS"

    [ "$STACK_STATUS" = "DELETE_COMPLETE" ] && break
    [ "$STACK_STATUS" = "DELETE_FAILED" ] && break

    sleep 20
  done
}

# ------------------------------------------------------------------------------------------
# Function Name ......: repairClusterStackIfNeeded
# Function Purpose ...: Cleanup VPC dependencies and retry stack delete if stack failed
# ------------------------------------------------------------------------------------------
# Argument ($1) ......: none
# Dependancies: ......: AWS_REGION, EKS_CLUSTER_NAME, deleteVpcDependencies()
# ------------------------------------------------------------------------------------------
# Return Value .......: none
# ------------------------------------------------------------------------------------------
repairClusterStackIfNeeded() {

  CLUSTER_STACK="eksctl-${EKS_CLUSTER_NAME}-cluster"

  STACK_STATUS=$(aws cloudformation describe-stacks \
    --stack-name "$CLUSTER_STACK" \
    --region "$AWS_REGION" \
    --query 'Stacks[0].StackStatus' \
    --output text 2>/dev/null)
  ret=$?

  [ $ret -ne 0 ] && return

  if [ "$STACK_STATUS" = "DELETE_FAILED" ]; then
    messageTitle "Repairing failed CloudFormation cluster stack ($CLUSTER_STACK)"

    VPC_ID=$(aws cloudformation list-stack-resources \
      --stack-name "$CLUSTER_STACK" \
      --region "$AWS_REGION" \
      --query "StackResourceSummaries[?ResourceType=='AWS::EC2::VPC'].PhysicalResourceId" \
      --output text 2>/dev/null)

    if [ -n "$VPC_ID" -a "$VPC_ID" != "None" ]; then
      echo " ▪ Found cluster VPC ....: $VPC_ID"

      deleteVpcDependencies "$VPC_ID"

      echo " ▪ Retry delete stack ...: $CLUSTER_STACK"
      aws cloudformation delete-stack \
        --stack-name "$CLUSTER_STACK" \
        --region "$AWS_REGION" \
        --no-cli-pager > /tmp/error.log 2>&1; ret=$?

      if [ $ret -ne 0 ]; then
        logMessages /tmp/error.log
        echo "ERROR: Failed to retry CloudFormation stack deletion"
        echo "       => aws cloudformation delete-stack --stack-name $CLUSTER_STACK --region $AWS_REGION"
        exit 1
      fi
    else
      echo "ERROR: Stack is DELETE_FAILED but no VPC resource was found"
      exit 1
    fi
  fi
}

# ------------------------------------------------------------------------------------------
# Function Name ......: verifyOrLoginSSO
# Function Purpose ...: Force AWS SSO login
# ------------------------------------------------------------------------------------------
# Dependencies .......: AWS_PROFILE
# ------------------------------------------------------------------------------------------
verifyOrLoginSSO() {
  unset AWS_SESSION_TOKEN AWS_SECRET_ACCESS_KEY AWS_ACCESS_KEY_ID AWS_SECURITY_TOKEN

  local PROFILE="${AWS_PROFILE:-AdministratorAccess-149536468416}"
  local ret

  echo "Force AWS SSO login (profile: $PROFILE)"
  aws sso login --profile "$PROFILE"
  ret=$?

  if [ $ret -ne 0 ]; then
    echo "ERROR: AWS SSO login failed"
    exit 1
  fi

  aws sts get-caller-identity --profile "$PROFILE" >/dev/null 2>&1
  ret=$?

  if [ $ret -ne 0 ]; then
    echo "ERROR: AWS SSO login succeeded, but STS still fails"
    exit 1
  fi

  export AWS_PROFILE="$PROFILE"
  echo "AWS SSO login successful (profile: $PROFILE)"
}

deleteClassicLoadBalancersInVpc() {
  vpcId="$1"

  aws elb describe-load-balancers \
    --region $AWS_REGION > /tmp/elbs.json 2>/dev/null

  for lb in $(jq -r --arg vpc "$vpcId" '.LoadBalancerDescriptions[]? | select(.VPCId == $vpc) | .LoadBalancerName' /tmp/elbs.json); do
    echo "Delete Classic Load Balancer: $lb"
    aws elb delete-load-balancer \
      --load-balancer-name "$lb" \
      --region $AWS_REGION > /tmp/error.log 2>&1; ret=$?
    [ $ret -ne 0 ] && logMessages /tmp/error.log
  done
}

deleteElbv2LoadBalancersInVpc() {
  vpcId="$1"

  aws elbv2 describe-load-balancers \
    --region $AWS_REGION > /tmp/elbv2.json 2>/dev/null

  for arn in $(jq -r --arg vpc "$vpcId" '.LoadBalancers[]? | select(.VpcId == $vpc) | .LoadBalancerArn' /tmp/elbv2.json); do
    echo "Delete ELBv2 Load Balancer: $arn"
    aws elbv2 delete-load-balancer \
      --load-balancer-arn "$arn" \
      --region $AWS_REGION > /tmp/error.log 2>&1; ret=$?
    [ $ret -ne 0 ] && logMessages /tmp/error.log
  done
}

terminateInstancesInVpc() {
  vpcId="$1"

  aws ec2 describe-instances \
    --region $AWS_REGION \
    --filters Name=vpc-id,Values=$vpcId Name=instance-state-name,Values=pending,running,stopping,stopped \
    > /tmp/instances.json 2>/dev/null

  for iid in $(jq -r '.Reservations[]?.Instances[]?.InstanceId' /tmp/instances.json); do
    echo "Disable EC2 termination protection: $iid"
