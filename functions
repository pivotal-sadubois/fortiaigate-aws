deleteEfsMountTargetsInVpc() {
  fsId="$1"
  vpcId="$2"

  aws efs describe-mount-targets \
    --file-system-id "$fsId" \
    --region $AWS_REGION \
    > /tmp/efs-mt.json 2>/dev/null

  for mt in $(jq -r --arg vpc "$vpcId" '.MountTargets[]? | select(.VpcId == $vpc) | .MountTargetId' /tmp/efs-mt.json); do
    echo "Delete EFS Mount Target: $mt"
    aws efs delete-mount-target \
      --mount-target-id "$mt" \
      --region $AWS_REGION > /tmp/error.log 2>&1; ret=$?
    [ $ret -ne 0 ] && logMessages /tmp/error.log
  done

  while true; do
    aws efs describe-mount-targets \
      --file-system-id "$fsId" \
      --region $AWS_REGION \
      > /tmp/efs-mt.json 2>/dev/null

    mtLeft=$(jq -r --arg vpc "$vpcId" '[.MountTargets[]? | select(.VpcId == $vpc)] | length' /tmp/efs-mt.json)
    [ "$mtLeft" == "0" ] && break

    echo "Waiting for EFS Mount Targets to disappear for filesystem $fsId ..."
    sleep 10
  done
}

deleteEfsFileSystemsInVpc() {
  vpcId="$1"

  aws efs describe-file-systems \
    --region $AWS_REGION \
    > /tmp/efs-fs.json 2>/dev/null

  for fsId in $(jq -r '.FileSystems[]? | .FileSystemId' /tmp/efs-fs.json); do

    aws efs describe-mount-targets \
      --file-system-id "$fsId" \
      --region $AWS_REGION \
      > /tmp/efs-mt.json 2>/dev/null

    fsInVpc=$(jq -r --arg vpc "$vpcId" '[.MountTargets[]? | select(.VpcId == $vpc)] | length' /tmp/efs-mt.json)

    [ "$fsInVpc" == "0" ] && continue

    echo "Delete EFS dependencies for filesystem: $fsId"

    deleteEfsAccessPointsInFileSystem "$fsId"
    deleteEfsMountTargetsInVpc "$fsId" "$vpcId"

    echo "Delete EFS File System: $fsId"
    aws efs delete-file-system \
      --file-system-id "$fsId" \
      --region $AWS_REGION > /tmp/error.log 2>&1; ret=$?
    [ $ret -ne 0 ] && logMessages /tmp/error.log
  done
}

# ------------------------------------------------------------------------------------------
# Function Name ......: verifyEksctlCredentials
# Function Purpose ...: Verify Installed EKSCTL Credendtials
# ------------------------------------------------------------------------------------------
# Argument ($1) ......: none
# Dependancies: ......: messageLine() 
# ------------------------------------------------------------------------------------------
# Return Value .......: none
# ------------------------------------------------------------------------------------------
# ------------------------------------------------------------------------------------------
# Function Name ......: verifyEksctlCredentials
# Function Purpose ...: Ensure AWS SSO-backed credentials are valid for eksctl / aws / kubectl
# ------------------------------------------------------------------------------------------
# Dependencies .......: AWS_PROFILE, AWS_REGION
# Return Value .......: 0 on success, 1 on failure
# ------------------------------------------------------------------------------------------
verifyEksctlCredentials() {
  local PROFILE="${AWS_PROFILE:-AdministratorAccess-149536468416}"
  local REGION="${AWS_REGION:-eu-north-1}"
  local ret

  echo " ▪ Verify AWS/eksctl credentials (profile: $PROFILE, region: $REGION)"

  # ----------------------------------------------------------------------------
  # 1) Generic credential check: can AWS CLI resolve valid credentials?
  # ----------------------------------------------------------------------------
  aws sts get-caller-identity --profile "$PROFILE" >/dev/null 2>/tmp/error.log
  ret=$?

  if [ $ret -eq 0 ]; then
    export AWS_PROFILE="$PROFILE"
    export AWS_REGION="$REGION"
    echo " ▪ AWS/eksctl credentials are valid"
    return 0
  fi

  echo " ▪ AWS credentials are not valid, refreshing AWS SSO session"

  # ----------------------------------------------------------------------------
  # 2) Refresh SSO session
  # ----------------------------------------------------------------------------
  aws sso login --profile "$PROFILE" >/tmp/error.log 2>&1
  ret=$?

  if [ $ret -ne 0 ]; then
    cat /tmp/error.log
    echo "ERROR: AWS SSO login failed for profile $PROFILE"
    return 1
  fi

  # ----------------------------------------------------------------------------
  # 3) Re-check credentials after login
  # ----------------------------------------------------------------------------
  aws sts get-caller-identity --profile "$PROFILE" >/dev/null 2>/tmp/error.log
  ret=$?

  if [ $ret -ne 0 ]; then
    cat /tmp/error.log
    echo "ERROR: AWS credentials are still invalid after SSO refresh"
    return 1
  fi

  # ----------------------------------------------------------------------------
  # 4) Optional EKS-specific sanity check for the target region
  # ----------------------------------------------------------------------------
  aws eks list-clusters --region "$REGION" --profile "$PROFILE" >/dev/null 2>/tmp/error.log
  ret=$?

  if [ $ret -ne 0 ]; then
    cat /tmp/error.log
    echo "ERROR: AWS credentials are valid, but EKS access failed in region $REGION"
    return 1
  fi

  export AWS_PROFILE="$PROFILE"
  export AWS_REGION="$REGION"

  echo " ▪ AWS SSO session refreshed successfully"
  echo " ▪ eksctl credentials are valid"
  return 0
}

# ------------------------------------------------------------------------------------------
# Function Name ......: installFAIGchart
# Function Purpose ...: Verify Installed CLI Utilities for Mac
# ------------------------------------------------------------------------------------------
# Argument ($1) ......: none
# Dependancies: ......: messageLine()
# ------------------------------------------------------------------------------------------
# Return Value .......: none
# ------------------------------------------------------------------------------------------
installFAIGchart() {
  # Environment Variables
  AWS_ACCOUNT_ID=$(aws sts get-caller-identity | jq -r '.Account')
  ECR_FORTIAIGATE_REPOSITORY="${AWS_ACCOUNT_ID}.dkr.ecr.${ECR_REGION}.amazonaws.com/fortiaigate"
  STAGEDIR=/tmp/faig_$ECR_FORTIAIGATE_TAG

  # Cleanup from previous Build
  [ -d $STAGEDIR ] && rm -rf $STAGEDIR; mkdir $STAGEDIR

  # ----------------------------------------------------------------------------------------
  # Unpack Helm Chart
  # ----------------------------------------------------------------------------------------
  CHARTFILE=$(ls -1 $ECR_FORTIAIGATE_SOURCE_DIR/FAIG_helm_chart*.tar)

  if [ -f "$CHARTFILE" ]; then 
    tar xf $CHARTFILE -C $STAGEDIR
  else
    echo "ERROR: Helm Chart file ($CHARTFILE) not found"
    exit 1
  fi

  # ----------------------------------------------------------------------------------------
  # 12.7 Fix 7: License Validation Bug (build0004)
  # https://github.com/asameli-ftnt/fortiaigate-doc?tab=readme-ov-file#128-fix-8-triton-hardcoded-image-tags-build0012
  # ----------------------------------------------------------------------------------------
  sed -i '' 's+triton-models:[0-9].*$+triton-models:{{ .Values.fortiaigate.image.tag }}+g' $STAGEDIR/fortiaigate/templates/triton-server.yaml
  sed -i '' 's+custom-triton:[0-9].*$+custom-triton:{{ .Values.fortiaigate.image.tag }}+g' $STAGEDIR/fortiaigate/templates/triton-server.yaml

  # ----------------------------------------------------------------------------------------
  # 12.2 Fix 2: Triton GPU Node Affinity
  # ----------------------------------------------------------------------------------------
  TEMPLATEFILE=$STAGEDIR/fortiaigate/templates/triton-server
  awk '
  /^[[:space:]]*nodeSelectorTerms:[[:space:]]*$/ {
    print
    print "              - matchExpressions:"
    print "                  - key: eks.amazonaws.com/nodegroup"
    print "                    operator: In"
    print "                    values:"
    print "                      - gpu-ng"
    print "                      - gpu-spot-ng"
    next
  }
  { print }
  ' ${TEMPLATEFILE}.yaml > ${TEMPLATEFILE}.yaml.tmp && mv ${TEMPLATEFILE}.yaml.tmp ${TEMPLATEFILE}.yaml


  # ----------------------------------------------------------------------------------------
  # Copy Licenses files to the chart directory
  # ----------------------------------------------------------------------------------------
  cp -r $FAID_LICENSE_DIR/* $STAGEDIR/fortiaigate/files/licenses/

  # ----------------------------------------------------------------------------------------
  # Make license mapping on the NodeGroup nodes
  # ----------------------------------------------------------------------------------------
  FAIG_LICENSES=()

  for f in "$HOME"/.faig/licenses/*.lic; do
    [ -e "$f" ] || continue
    FAIG_LICENSES+=("$(basename "$f")")
  done

  nodes=$(kubectl get nodes -L eks.amazonaws.com/nodegroup -o json | jq -r '.items[].metadata.name')
  nodes=$(kubectl get nodes -L eks.amazonaws.com/nodegroup -o json  | jq -r '.items[].metadata | select(.labels."alpha.eksctl.io/nodegroup-name" == "faig-ng").name')

  i=0;
  echo "  licenses:" > /tmp/values-licenses.yaml
  for node in ${nodes}; do
    lic=${FAIG_LICENSES[$i]}

    echo "    \"$node\":  \"files/licenses/$lic\"" >> /tmp/values-licenses.yaml
    let i=i+1
  done

  #ECR_FORTIAIGATE_REPOSITORY="${AWS_ACCOUNT_ID}.dkr.ecr.${ECR_REGION}.amazonaws.com/fortiaigate"

  sed -e "s+XXX_REPONAME_XXX+$ECR_FORTIAIGATE_REPOSITORY+g" \
      -e "s/XXXEFSSCXXX/$EFS_STORAGE_CLASS/g" \
      -e "s/XXX_REPOTAG_XXX/$ECR_FORTIAIGATE_TAG/g" \
      -e '/^XXXLICENSESXXX$/{r /tmp/values-licenses.yaml' -e ';d;}' cfg/values-template.yaml > /tmp/values.yaml

  echo "helm install fortiaigate ${STAGEDIR}/fortiaigate -n fortiaigate -f /tmp/values.yaml --create-namespace"
}

# ------------------------------------------------------------------------------------------
# Function Name ......: deleteImagebyTag
# Function Purpose ...: Delete ECR Repository Images by Tag
# ------------------------------------------------------------------------------------------
# Argument ($1) ......: TAG ie. build0015
# Dependancies: ......: messageLine()
# ------------------------------------------------------------------------------------------
# Return Value .......: none
# ------------------------------------------------------------------------------------------
deleteImagebyTag() {
  local TAG="$1"
  local REGION="${ECR_REGION:-$AWS_REGION}"

  for repo in $(aws ecr describe-repositories \
    --region "$REGION" \
    --query 'repositories[].repositoryName' \
    --output text); do

    local image_ids
    if [ -n "$TAG" ]; then
      image_ids=$(aws ecr list-images \
        --region "$REGION" \
        --repository-name "$repo" \
        --filter tagStatus=TAGGED \
        --query "imageIds[?imageTag=='$TAG']" \
        --output json)
    else
      image_ids=$(aws ecr list-images \
        --region "$REGION" \
        --repository-name "$repo" \
        --filter tagStatus=ANY \
        --query 'imageIds' \
        --output json)
    fi

    [ "$image_ids" = "[]" ] && continue

    local tmpfile
    tmpfile=$(mktemp)

    printf '%s\n' "$image_ids" > "$tmpfile"

    aws ecr batch-delete-image \
      --region "$REGION" \
      --repository-name "$repo" \
      --image-ids "file://$tmpfile" \
      --output json \
    | awk -v repo="$repo" '
        /"imageTag":/ {
          gsub(/[",]/, "", $2)
          print " ▪ Images in repistory: " repo ":" $2 " deleted"
        }
      '

    rm -f "$tmpfile"
  done
}


getImageTags() {
  for repo in $(aws ecr describe-repositories \
    --region eu-north-1 \
    --query 'repositories[].repositoryName' \
    --output text); do
  
    aws ecr describe-images \
      --region eu-north-1 \
      --repository-name "$repo" \
      --query 'imageDetails[].imageTags[]' \
      --output text 2>/dev/null | tr '\t' '\n' | sort -u
  done

}

